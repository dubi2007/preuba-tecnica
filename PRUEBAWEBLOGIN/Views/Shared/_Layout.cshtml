<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Gestión de usuarios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body class="bg-light @((ViewData["ShowSidebar"] as bool? == true) ? "" : "d-flex flex-column min-vh-100")">

    <!-- Reusable Top Header -->
    <header class="app-header d-flex justify-content-between align-items-center px-4 m-0" style="@((ViewData["ShowSidebar"] as bool? == true) ? "margin-left:80px !important;" : "")">
        <div class="header-title text-white">@(ViewData["HeaderTitle"] ?? "Gestión de usuarios")</div>
        <div class="header-actions text-white fw-bold fs-4 d-flex align-items-center gap-3">
            <span>?</span>
            @if (User.Identity!.IsAuthenticated)
            {
                <i class="bi bi-bell-fill fs-5"></i>
                <div class="d-flex align-items-center ms-3 text-end lh-1">
                    <i class="bi bi-person-circle fs-3 me-2"></i>
                    <div style="font-size: 0.9rem; font-weight: normal; font-family: sans-serif;">
                        <div class="fw-bold">@User.Identities.FirstOrDefault()?.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value</div>
                        <div class="small opacity-75 text-end">@User.Identities.FirstOrDefault()?.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-link text-white p-0 ms-3" title="Cerrar sesión"><i class="bi bi-box-arrow-right fs-4"></i></button>
                </form>
            }
        </div>
    </header>

    @if (ViewData["ShowSidebar"] as bool? == true)
    {
        <div class="profile-layout d-flex w-100" style="min-height: calc(100vh - 60px);">
            <!-- Barra lateral -->
            <aside class="sidebar bg-white flex-shrink-0" style="width: 80px; box-shadow: 2px 0 5px rgba(0,0,0,0.05); z-index: 1000; position:fixed; left:0; top:60px; bottom:0;">
                <div class="mt-3 mb-4 text-center text-primary fs-3" style="cursor:pointer;">
                    <i class="bi bi-list"></i>
                </div>
                <div class="d-flex flex-column gap-4 align-items-center w-100">
                    <div class="sidebar-icon"><i class="bi bi-house-door"></i></div>
                    <div class="sidebar-icon"><i class="bi bi-building"></i></div>
                    <div class="sidebar-icon active px-3 py-2" style="background-color: #ffeaea; color: #dc3545; border-radius: 8px;"><i class="bi bi-file-earmark-person"></i></div>
                    <div class="sidebar-icon"><i class="bi bi-search"></i></div>
                </div>
            </aside>

            <!-- Contenido principal -->
            <main class="d-flex flex-column" style="margin-left: 80px; width: calc(100% - 80px); min-height: calc(100vh - 60px);">
                <div class="container-fluid p-4 flex-grow-1" style="max-width: 1200px;">
                    @RenderBody()
                </div>

                <!-- Pie de página -->
                @await Html.PartialAsync("_Footer")
            </main>
        </div>
    }
    else
    {
        @RenderBody()

        <!-- Pie de página -->
        @await Html.PartialAsync("_Footer")
    }

    <!-- Modal de advertencia de sesión -->
    @if (User.Identity!.IsAuthenticated)
    {
        <div class="modal fade" id="sessionWarningModal" tabindex="-1" aria-labelledby="sessionWarningModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" style="max-width: 820px;">
                <div class="modal-content shadow-lg border-0" style="border-radius: 12px; overflow: hidden; background-color: #f6f5f3;">
                    <div class="modal-body p-4">
                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-exclamation-triangle-fill text-warning fs-3 me-3" style="margin-top: 2px;"></i>
                            <div>
                                <h5 class="modal-title fw-bold mb-2" id="sessionWarningModalLabel">Su sesión esta a punto de expirar</h5>
                                <p class="mb-0 text-muted small">
                                    Por seguridad, su sesión expirará en <span id="sessionCountdown" class="fw-bold">49</span> segundos. Para continuar, seleccione "Extender sesión"
                                </p>
                            </div>
                        </div>
                        <div class="text-end">
                            <button type="button" class="btn px-4 fw-semibold" id="btnExtendSession" style="color:#fff; background-color:#ca8a04; border-color:#ca8a04; border-radius: 8px;">Extender sesión</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    
    @if (User.Identity!.IsAuthenticated)
    {
        <script>
            $(document).ready(function () {
                const sessionTimeoutSeconds = 60; // 60 seconds total session time (for testing)
                const warningTimeSeconds = 49; // Show warning with 49 seconds remaining
                
                let countdownInterval;
                let sessionTimeout;
                let warningTimeout;

                const modalEl = document.getElementById('sessionWarningModal');
                const bsModal = new bootstrap.Modal(modalEl);

                function startTimers() {
                    clearTimeout(sessionTimeout);
                    clearTimeout(warningTimeout);
                    clearInterval(countdownInterval);

                    warningTimeout = setTimeout(() => {
                        let remaining = warningTimeSeconds;
                        $('#sessionCountdown').text(remaining);
                        bsModal.show();

                        countdownInterval = setInterval(() => {
                            remaining--;
                            $('#sessionCountdown').text(remaining);
                            if (remaining <= 0) {
                                clearInterval(countdownInterval);
                                window.location.href = '@Url.Action("Logout", "Account", new { expired = true })';
                            }
                        }, 1000);
                    }, (sessionTimeoutSeconds - warningTimeSeconds) * 1000);
                }

                $('#btnExtendSession').click(function () {
                    $.post('@Url.Action("ExtendSession", "Account")', function () {
                        bsModal.hide();
                        startTimers();
                    });
                });

                startTimers();
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>