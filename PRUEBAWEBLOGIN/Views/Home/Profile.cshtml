@model PRUEBAWEBLOGIN.Models.User
@{
    ViewData["Title"] = "Perfil de usuario";
    ViewData["ShowSidebar"] = true;
}

<div class="mb-4">
    <div class="text-muted small">Perfil de usuario</div>
    <h1 class="fw-bold mb-4">Perfil de usuario</h1>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <!-- Encabezado del perfil -->
        <div class="d-flex align-items-center gap-4 mb-4">
            <div class="user-avatar" style="width:100px; height:100px; background-color: #b0c4de; font-size: 3rem;">
                <i class="bi bi-person-fill"></i>
            </div>
            <div>
                <div class="d-flex align-items-center gap-3 mb-1">
                    <h4 class="fw-bold m-0 fs-3">@Model?.FullName</h4>
                    <span class="badge fw-semibold" style="background-color: #7ac143; color: #ffffff; border-radius: 20px; padding: 5px 14px; font-size: 0.8rem;">@Model?.Status</span>
                </div>
                <div class="text-secondary fw-semibold mb-1">@Model?.Role</div>
                <div class="text-secondary small">@Model?.Institution</div>
            </div>
        </div>

        <!-- Pestañas -->
        <ul class="nav nav-tabs mb-4 px-2" id="profileTabs" role="tablist">
            <li class="nav-item flex-fill text-center" role="presentation">
                <button class="nav-link active w-100 py-3 fw-bold" id="basic-tab" data-bs-toggle="tab" data-bs-target="#basic" type="button" role="tab" style="border-bottom: 2px solid #0d6efd;">Información básica</button>
            </li>
            <li class="nav-item flex-fill text-center" role="presentation">
                <button class="nav-link w-100 py-3 text-muted fw-semibold" id="resp-tab" data-bs-toggle="tab" data-bs-target="#resp" type="button" role="tab">Responsabilidades</button>
            </li>
            <li class="nav-item flex-fill text-center" role="presentation">
                <button class="nav-link w-100 py-3 text-muted fw-semibold" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">Historial de responsabilidades</button>
            </li>
        </ul>

        <!-- Contenido de pestañas -->
        <div class="tab-content" id="profileTabsContent">
            <div class="tab-pane fade show active" id="basic" role="tabpanel">
                <form class="row g-4">
                    <!-- Fila 1: Documento y nombres -->
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Tipo de Documento de Identidad</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.DocumentType" readonly>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">N° de Documento de Identidad</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.DocumentNumber" readonly>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Nombres</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.FirstName" readonly>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Apellidos</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.LastName1 @Model?.LastName2" readonly>
                    </div>

                    <!-- Fila 2: Datos demográficos -->
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Nacionalidad</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.Nationality" readonly>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Sexo</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.Gender" readonly>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Estado validación PIDE</label>
                        <input type="text" class="form-control bg-light border-0" value="Validado" readonly>
                    </div>
                    <div class="col-md-3"></div>

                    <!-- Fila 3: Contacto y contratación -->
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Correo electrónico principal</label>
                        <div class="position-relative text-secondary d-flex align-items-center">
                            <input type="email" class="form-control bg-light border-0 pe-4 text-secondary" value="@Model?.MainEmail" readonly>
                            <i class="bi bi-pencil position-absolute end-0 me-2 text-primary" style="cursor:pointer;"></i>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Teléfono Móvil</label>
                        <div class="position-relative text-secondary d-flex align-items-center">
                            <input type="text" class="form-control bg-light border-0 pe-4 text-secondary" value="@Model?.MobilePhone" readonly>
                            <i class="bi bi-pencil position-absolute end-0 me-2 text-primary" style="cursor:pointer;"></i>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Tipo de Contratación</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.ContractType" readonly>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small fw-semibold">Fecha de nacimiento</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model?.BirthDate" readonly>
                    </div>
                </form>
            </div>
            <div class="tab-pane fade" id="resp" role="tabpanel">
                <p class="text-muted p-4">No hay responsabilidades registradas.</p>
            </div>
            <div class="tab-pane fade" id="history" role="tabpanel">
                <p class="text-muted p-4">Historial vacío.</p>
            </div>
        </div>
    </div>
</div>